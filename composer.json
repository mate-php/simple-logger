{
    "name": "matephp/simple-logger",
    "description": "MatePHP - Simple Logger",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "logger",
        "psr",
        "psr-3",
        "logging",
        "log",
        "profiling"
    ],
    "require": {
        "php": "^8.4",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "pestphp/pest": "^4.6",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Mate\\Logger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:coverage": "pest --coverage-html build/coverage",
        "test": "pest",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "fix": "PHP_CS_FIXER_IGNORE_ENV=1 vendor/bin/php-cs-fixer fix",
        "stan": "vendor/bin/phpstan analyse src",
        "check-all": [
            "@putenv COMPOSER_AUDIT_ABANDONED=fail",
            "composer audit",
            "composer stan",
            "vendor/bin/pest"
        ]
    }
}